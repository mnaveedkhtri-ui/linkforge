# Copy this file to .env and fill in real values before running the app.

# Required for AI Copilot, Content Studio generation, and the humanize feature.
# Get a free key (no credit card needed) at https://console.groq.com/keys
GROQ_API_KEY=

# Any long random string. Used to sign login sessions.
SESSION_SECRET=change-this-to-a-long-random-string

# Port the server listens on. Most hosts set this automatically.
PORT=3000
